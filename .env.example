# ==========================================================================
# Solen - variaveis de ambiente (copie para .env e preencha)
# ==========================================================================

# ---- Supabase (Banco / Auth / Storage) ----
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # apenas na API (NUNCA expor no frontend)
SUPABASE_STORAGE_BUCKET=catalog

# ---- Banco de dados (Postgres do Supabase, usado pelo Prisma na API) ----
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres
# Connection pooling (recomendado em serverless):
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# ---- API (NestJS) ----
API_PORT=3333
API_BASE_URL=http://localhost:3333
CORS_ORIGIN=http://localhost:3000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- WhatsApp ----
WHATSAPP_PHONE=5599999999999        # numero que recebe as propostas (DDI+DDD+numero)

# ---- Integracoes ----
VIACEP_BASE_URL=https://viacep.com.br/ws   # gratuito, sem chave
