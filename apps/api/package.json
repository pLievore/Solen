{
  "name": "@vendy/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "create-admin": "dotenv -e ../../.env -- ts-node scripts/create-admin.ts",
    "set-admin-role": "dotenv -e ../../.env -- ts-node scripts/set-admin-role.ts",
    "auth:check": "dotenv -e ../../.env -- ts-node scripts/check-admin-auth.ts",
    "security:check": "dotenv -e ../../.env -- ts-node scripts/check-database-security.ts",
    "seo:publish": "dotenv -e ../../.env -- ts-node scripts/publish-seo-posts.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test -r ts-node/register src/evaluation/pricing.engine.spec.ts src/evaluation/quote.service.spec.ts src/blog/sanitize-post-html.spec.ts src/auth/auth.guard.spec.ts",
    "lint": "eslint \"{src,scripts}/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@supabase/realtime-js": "^2.108.2",
    "@supabase/supabase-js": "^2.108.2",
    "@vendy/shared": "workspace:*",
    "helmet": "^8.2.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.14.0",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.5",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
