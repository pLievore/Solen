{
  "name": "vendy",
  "version": "0.0.0",
  "private": true,
  "description": "Site de captacao de leads para compra de eletronicos usados (iPhones, iPads, consoles, etc.)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.18.0"
  },
  "pnpm": {
    "overrides": {
      "multer": "2.2.0",
      "postcss": "8.5.15",
      "qs": "6.15.2"
    }
  },
  "scripts": {
    "dev:web": "pnpm --filter @vendy/web dev",
    "dev:api": "pnpm --filter @vendy/api dev",
    "build": "pnpm --filter @vendy/shared build && pnpm -r build",
    "e2e": "playwright test",
    "lint": "pnpm -r lint",
    "monitor:production": "node scripts/check-production.mjs",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @vendy/api prisma:migrate",
    "db:seed": "pnpm --filter @vendy/api db:seed",
    "db:studio": "pnpm --filter @vendy/api prisma:studio"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
